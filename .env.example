# ===== Meta (Instagram orgánico + Facebook orgánico + Meta Ads) =====
# Token de larga duración o de System User con permisos:
#   read_insights, pages_read_engagement, pages_show_list, instagram_basic, instagram_manage_insights, ads_read, business_management
META_ACCESS_TOKEN=

# IDs de Más Center:
META_AD_ACCOUNT_ID=523272021711752   # "Cuenta Publicitarias MÁS CENTER / TIERRA CALMA" (con o sin act_)
META_PAGE_ID=61569210110437          # Página de Facebook de Más Center (web.facebook.com/profile.php?id=61569210110437)
META_IG_USER_ID=17841402331163198    # Instagram Business @mascenter (resuelve también desde la página)

# La cuenta es compartida "MÁS CENTER / TIERRA CALMA". Por defecto se ocultan las campañas
# de Tierra Calma. Para cambiar el filtro, pon substrings separados por coma (en minúsculas):
# META_EXCLUDE_CAMPAIGNS=tierra calma

# Opcionales
# META_GRAPH_VERSION=v21.0
# SOCIAL_MONTHS=12                    # meses de historial a traer
# DASHBOARD_CACHE_MS=600000           # caché en memoria (10 min)

# ===== GA4 (Google Analytics) — mismas credenciales que el dashboard de Ebema =====
GA4_PROPERTY_ID=                     # property de Más Center
# Opción A: OAuth de un usuario con acceso a GA
# GOOGLE_OAUTH_CLIENT_ID=
# GOOGLE_OAUTH_CLIENT_SECRET=
# GOOGLE_OAUTH_REFRESH_TOKEN=
# Opción B: cuenta de servicio con acceso de lectura en GA
# GA_SERVICE_ACCOUNT_JSON={"type":"service_account","client_email":"...","private_key":"..."}

# ===== LinkedIn (Página de empresa Grupo IFB, API en vivo) =====
# Token OAuth con scopes r_organization_social (+ rw_organization_admin). Ver README.
LINKEDIN_ACCESS_TOKEN=
LINKEDIN_ORG_ID=69230307             # Grupo IFB (linkedin.com/company/grupoifb → urn:li:organization:69230307)
# LINKEDIN_VERSION=202401            # versión de la API, formato YYYYMM

# ===== Modo edición (versión interna con clave) =====
# Clave para entrar a /?edit y editar conclusiones + competencia.
EDIT_PASSWORD=
# Almacenamiento compartido para que lo editado lo vea el cliente (Vercel Blob, GRATIS en Hobby).
# Vercel Blob moderno inyecta BLOB_STORE_ID vía OIDC (no necesita token).
# BLOB_READ_WRITE_TOKEN=

# ===== Protección opcional del link (HTTP Basic). Vacías = link ABIERTO =====
# DASHBOARD_USER=mascenter
# DASHBOARD_PASSWORD=una_clave_segura
